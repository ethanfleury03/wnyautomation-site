# WNY Automation Website staging environment.
# Copy these values into the Vercel Preview environment scoped to the staging branch.

APP_ENV=staging
NEXT_PUBLIC_SITE_URL=https://wnyautomation-git-staging-wny-automation.vercel.app
NEXT_PUBLIC_CLIENT_LOGIN_URL=https://wnyautomation-portal-gateway-git-staging-wny-automation.vercel.app/sign-in?redirect_url=/launch
NEXT_PUBLIC_BUSINESS_NAME=WNY Automation
NEXT_PUBLIC_BUSINESS_PHONE=
NEXT_PUBLIC_BUSINESS_EMAIL=
NEXT_PUBLIC_PRIMARY_CITY=Buffalo
NEXT_PUBLIC_PRIMARY_REGION=Western New York

CLERK_SECRET_KEY=sk_test_replace_me
CLERK_PROXY_URL=https://wnyautomation.com/clerk-proxy

# Optional but required for persistent staging blog/leads seed data.
DATABASE_URL=postgres://staging-site-user:staging-password@staging-site-host/staging-site-db?sslmode=require
BLOG_API_TOKEN=replace-with-staging-blog-token

# Keep lead/webhook delivery disabled unless explicitly testing it.
N8N_LEAD_WEBHOOK_URL=

# Optional staging-only media bucket.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=

# Analytics should stay empty in staging unless explicitly testing tags.
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_GSC_VERIFICATION=
NEXT_PUBLIC_META_PIXEL_ID=
